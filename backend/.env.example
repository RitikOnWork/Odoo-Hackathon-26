# Server
PORT=5000
NODE_ENV=development

# CORS — set to your frontend origin in production (e.g. https://your-app.com)
# Leave as * for local development (default when omitted)
CORS_ORIGIN=http://localhost:3000

# Database
MONGO_URI=mongodb://localhost:27017/transitops

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=10
